rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function isAdmin() {
      return signedIn() && userDoc(request.auth.uid).data.role == "admin";
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    match /users/{uid} {
      allow create: if isOwner(uid)
        && request.resource.data.role == "user";

      allow read: if isOwner(uid) || isAdmin();

      allow update: if isAdmin()
        || (
          isOwner(uid)
          && request.resource.data.role == resource.data.role
        );

      allow delete: if isAdmin() && !isOwner(uid);
    }

    match /clientes/{clienteId} {
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid;

      allow read: if isAdmin()
        || resource.data.userId == request.auth.uid;

      allow update, delete: if isAdmin()
        || resource.data.userId == request.auth.uid;
    }

    match /config/{docId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /notificacoes/{notifId} {
      // Apenas o admin gera notificações (ex: ao ativar a instalação de um cliente)
      allow create: if isAdmin()
        && request.resource.data.userId is string
        && request.resource.data.lida == false;

      // Cada vendedor só lê as próprias notificações; admin lê todas
      allow read: if signedIn()
        && (resource.data.userId == request.auth.uid || isAdmin());

      // O destinatário só pode alterar o campo "lida" (marcar como lida)
      allow update: if signedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lida']);

      allow delete: if isAdmin()
        || (signedIn() && resource.data.userId == request.auth.uid);
    }
  }
}
